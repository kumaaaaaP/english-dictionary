    {
      "number": 11001,
      "word": "propose",
      "pos": "動詞",
      "meaning": "①〜を提案する ②（to ～）〜に結婚を申し込む",
      "nuance": "一般的な提案から、結婚の申し込みまで幅広く使われる。特に結婚の意味では “propose to 人” の形が定型。",
      "example_sections": [
        {
          "title": "例文（提案）",
          "examples": [
            {
              "en": "She proposed a new plan to improve productivity.",
              "ja": "彼女は生産性を向上させる新しい計画を提案した。",
              "highlight": "proposed"
            },
            {
              "en": "I propose that we take a short break.",
              "ja": "短い休憩を取ることを提案します。",
              "highlight": "propose"
            }
          ]
        },
        {
          "title": "例文（結婚）",
          "examples": [
            {
              "en": "He finally proposed to her after five years of dating.",
              "ja": "5年間の交際を経て、彼はついに彼女にプロポーズした。",
              "highlight": "proposed"
            }
          ]
        }
      ],
      "etymology": "pro（前に）＋ pose（置く）→ 前に差し出す → 提案する",
      "synonyms": [
        {"word": "suggest", "trans": "提案する"},
        {"word": "offer", "trans": "申し出る"},
        {"word": "recommend", "trans": "勧める"}
